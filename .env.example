# ============================================================
# Google Drive File Discovery Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Gemini AI ────────────────────────────────────────────────
# Your Google AI Studio API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Google Drive API ─────────────────────────────────────────
# Path to your Service Account JSON key file
# OR paste the entire JSON string (for cloud deployment)
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json

# (Optional) Restrict searches to a specific Google Drive folder
# Leave empty to search all files accessible by the service account
GOOGLE_DRIVE_FOLDER_ID=

# ── Backend ──────────────────────────────────────────────────
# Backend server host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ─────────────────────────────────────────────────
# URL where the FastAPI backend is running
# For local dev: http://localhost:8000
# For production: https://your-backend-url.onrender.com
BACKEND_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
